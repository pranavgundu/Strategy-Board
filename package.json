{
  "name": "strategy-board",
  "version": "2026.2.0",
  "description": "The Digital Strategy Whiteboard for FRC",
  "packageManager": "bun@1.2.5",
  "homepage": "https://github.com/pranavgundu/strategy-board",
  "author": {
    "name": "Pranav Gundu",
    "email": "pranav@strategyboard.app"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host",
    "build": "tsx scripts/commit.ts && tsc && vite build",
    "preview": "vite preview --host",
    "spell": "cspell \"**/*.{ts,tsx,js,jsx,html,md}\"",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "assets": "cp favicon/icon-512.png assets/icon.png && cp favicon/icon-512.png assets/icon-only.png && bunx capacitor-assets generate --iconBackgroundColor '#18181b' --iconBackgroundColorDark '#18181b' --splashBackgroundColor '#18181b' --splashBackgroundColorDark '#18181b'",
    "cap:sync": "bun run build && bunx cap sync",
    "cap:open:ios": "bunx cap open ios",
    "cap:open:android": "bunx cap open android",
    "cap:run:ios": "bun run cap:sync && bunx cap run ios",
    "cap:run:android": "bun run cap:sync && bunx cap run android",
    "cap:build:android": "bun run cap:sync && cd android && ./gradlew assembleDebug && cp app/build/outputs/apk/debug/app-debug.apk ../release/\"Strategy Board-$(bun -e \"console.log(require('../package.json').version)\").apk\"",
    "cap:build:ios": "bun run cap:sync && cd ios/App && xcodebuild -workspace App.xcworkspace -scheme App -configuration Debug -sdk iphonesimulator -derivedDataPath ../../release/ios-build archive",
    "electron:dev": "concurrently \"vite --host\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "bun run build && electron-builder",
    "electron:build:mac": "bun run build && electron-builder --mac",
    "electron:build:win": "bun run build && electron-builder --win",
    "electron:build:linux": "bun run build && electron-builder --linux",
    "electron:build:all": "bun run build && electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "com.strategyboard.app",
    "productName": "Strategy Board",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "favicon/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "favicon/icon-512.png",
      "artifactName": "Strategy.Board-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "favicon/favicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "favicon/favicon.ico",
      "artifactName": "Strategy.Board.Setup.${version}.${ext}"
    },
    "portable": {
      "artifactName": "Strategy.Board.${version}.${ext}"
    },
    "linux": {
      "icon": "favicon/icon-512.png",
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "appImage": {
      "artifactName": "Strategy.Board-${version}.${ext}"
    },
    "deb": {
      "artifactName": "strategy-board_${version}_${arch}.${ext}"
    }
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@eslint/js": "^10.0.1",
    "@types/marked": "^6.0.0",
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "cspell": "^9.7.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-static-copy": "^4.0.0",
    "wait-on": "^9.0.4",
    "workbox-window": "^7.4.0"
  },
  "ignoredBuiltDependencies": [
    "@firebase/util",
    "core-js",
    "esbuild",
    "protobufjs"
  ],
  "overrides": {
    "tar": ">=7.5.8",
    "minimatch": ">=10.2.1",
    "serialize-javascript": ">=7.0.3"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "es-abstract": "^1.24.1",
    "firebase": "^12.11.0",
    "idb-keyval": "^6.2.2",
    "jspdf": "^4.2.1",
    "marked": "^17.0.5",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.2.2",
    "uuid": "^13.0.0"
  }
}
